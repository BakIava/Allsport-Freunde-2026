# Neon Postgres – Diese Werte werden automatisch gesetzt,
# wenn du eine Neon-Datenbank im Vercel-Dashboard verbindest.
# Lokal kannst du sie mit `npx vercel env pull .env.local` herunterladen.

POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Alternativ (Neon direkt):
# DATABASE_URL=

# NextAuth.js – Generiere ein Secret mit: openssl rand -base64 32
# Wird auf Vercel automatisch gesetzt
AUTH_SECRET=

# Admin-Zugangsdaten (optional – Standard: admin/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# E-Mail (Resend) – Optional, ohne API-Key werden E-Mails nur geloggt
RESEND_API_KEY=
EMAIL_FROM=Allsport Freunde <noreply@allsport-freunde.de>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# QR-Code Check-In – Secret zum Signieren der Check-In JWTs
# Generiere mit: openssl rand -base64 32
CHECKIN_SECRET=

# Kontaktformular – E-Mail-Adresse des Admins für Benachrichtigungen
# Falls nicht gesetzt, wird EMAIL_FROM verwendet
ADMIN_EMAIL=

# Cron-Job – Erinnerungsmails (täglich 08:00 UTC via Vercel Cron)
# Generiere mit: openssl rand -base64 32
# In Vercel setzen: Dashboard → Project Settings → Environment Variables
CRON_SECRET=
